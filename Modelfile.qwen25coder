# Modelfile for qwen2.5-coder:7b-instruct — optimised for the ml-agent on a T550 (4GB VRAM)
#
# Usage:
#   ollama pull qwen2.5-coder:7b-instruct
#   ollama create ml-agent -f Modelfile.qwen25coder
#   Then set model_name to "ollama/ml-agent" in configs/cli_agent_config.json
#
# Tuning rationale (from benchmarks):
#   num_gpu 18  — partial offload on T550. 18 × ~165MB/layer ≈ 3.0GB, well under 4GB.
#                 Gives ~15-20 tok/s vs 8-12 tok/s pure CPU. Increase by 2 if stable,
#                 back off by 2 if you see CUDA OOM. For pure CPU: set num_gpu 0.
#   num_ctx 4096 — KV cache at 4K ≈ 200-400MB VRAM vs 400-800MB at 8K.
#                  Agent system+tool prompt is ~1800 tokens, leaving ~2200 for output.
#   temperature 0.1 — critical for tool-call reliability. Default 0.8 causes hallucinated
#                     tool names and malformed JSON. Lower = more deterministic JSON output.
#   num_thread 10  — physical cores minus 2 for the CPU layers. Adjust for your CPU.
#                    For 12 physical cores: 10. For 8 physical cores: 6.
#   num_batch 256  — prompt processing batch size. Higher = faster prefill.
#
# Note: "mmap" is not a valid Modelfile parameter in current Ollama versions
# (API-only option) — `ollama create` rejects it. Do not add it here.

FROM qwen2.5-coder:7b-instruct

PARAMETER num_gpu 18
PARAMETER num_thread 10
PARAMETER num_ctx 4096
PARAMETER temperature 0.1
PARAMETER num_batch 256
